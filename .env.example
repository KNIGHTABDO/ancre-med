# Gemini API Key (required) — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Turso Database (required for production / Vercel)
# Create at https://turso.tech — free tier includes 9GB storage
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-token-here

# Local development fallback (optional)
# If TURSO_DATABASE_URL is not set, the app falls back to file:clinical_ground_truth.db

# v2 rollout flags. Enabled by default for production-grade clinical performance.
ANCREMED_V2_DEEP_SEARCH=true
ANCREMED_V2_GATE_SPANS=true
ANCREMED_V2_FORMULA_BANK=true
ANCREMED_V2_VERIFIER_FRESHNESS=true
ANCREMED_V2_QUALITY_POLISH=true

